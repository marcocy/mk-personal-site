---
const {
  title = 'Marcos Kallis',
  description = 'Personal blog, ideas lab and web app portfolio.'
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      :root {
        --bg: #f7f3ec;
        --paper: #fffaf2;
        --ink: #1f2933;
        --muted: #697586;
        --accent: #e8792e;
        --accent-dark: #b95718;
        --line: rgba(31, 41, 51, 0.12);
        --shadow: 0 24px 60px rgba(31, 41, 51, 0.10);
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(232,121,46,0.14), transparent 32rem),
          linear-gradient(180deg, #fdf8ef 0%, var(--bg) 100%);
        color: var(--ink);
        line-height: 1.6;
      }
      a { color: var(--accent-dark); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .container { width: min(1100px, calc(100% - 32px)); margin: 0 auto; }
      header.site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(14px);
        background: rgba(247,243,236,0.78);
        border-bottom: 1px solid var(--line);
      }
      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 18px;
        padding: 14px 0;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--ink);
      }
      .brand-mark {
        display: inline-grid;
        place-items: center;
        width: 34px;
        height: 34px;
        border-radius: 12px;
        background: var(--accent);
        color: white;
        box-shadow: 0 12px 28px rgba(232,121,46,0.28);
      }
      nav.links { display: flex; gap: 14px; flex-wrap: wrap; justify-content: flex-end; }
      nav.links a {
        color: var(--ink);
        font-weight: 650;
        font-size: 0.95rem;
        padding: 8px 10px;
        border-radius: 999px;
      }
      nav.links a:hover { background: rgba(232,121,46,0.12); text-decoration: none; }
      main { padding: 54px 0 70px; }
      .hero {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 28px;
        align-items: stretch;
      }
      .card {
        background: rgba(255,250,242,0.88);
        border: 1px solid var(--line);
        border-radius: 28px;
        box-shadow: var(--shadow);
      }
      .hero-card { padding: clamp(28px, 5vw, 56px); }
      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--accent-dark);
        font-weight: 800;
        font-size: 0.86rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 16px;
      }
      h1, h2, h3 { line-height: 1.08; letter-spacing: -0.045em; }
      h1 { font-size: clamp(2.25rem, 7vw, 5rem); margin: 0 0 20px; }
      h2 { font-size: clamp(1.7rem, 3.5vw, 2.7rem); margin: 0 0 16px; }
      h3 { font-size: 1.25rem; margin: 0 0 8px; }
      p { color: var(--muted); }
      .lead { font-size: clamp(1.05rem, 2vw, 1.25rem); max-width: 60ch; }
      .button-row { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 28px; }
      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 10px 18px;
        border-radius: 999px;
        font-weight: 800;
        border: 1px solid var(--line);
      }
      .button.primary { background: var(--accent); color: white; border-color: var(--accent); }
      .button.secondary { background: white; color: var(--ink); }
      .side-card { padding: 28px; display: grid; align-content: center; }
      .stat {
        padding: 18px 0;
        border-bottom: 1px solid var(--line);
      }
      .stat:last-child { border-bottom: 0; }
      .stat strong { display: block; font-size: 1.75rem; letter-spacing: -0.04em; }
      .section { margin-top: 44px; }
      .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
      }
      .mini-card { padding: 24px; }
      .post-list { display: grid; gap: 18px; }
      .post-card { padding: 24px; display: grid; gap: 6px; }
      .post-card time { color: var(--muted); font-size: 0.93rem; }
      .prose {
        width: min(820px, 100%);
        margin: 0 auto;
        background: rgba(255,250,242,0.88);
        border: 1px solid var(--line);
        border-radius: 28px;
        padding: clamp(24px, 5vw, 56px);
        box-shadow: var(--shadow);
      }
      .prose img { max-width: 100%; border-radius: 20px; }
      footer {
        border-top: 1px solid var(--line);
        padding: 28px 0 42px;
        color: var(--muted);
      }
      @media (max-width: 820px) {
        .hero { grid-template-columns: 1fr; }
        .grid { grid-template-columns: 1fr; }
        .nav { align-items: flex-start; flex-direction: column; }
        nav.links { justify-content: flex-start; }
        main { padding-top: 34px; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container nav">
        <a class="brand" href="/" aria-label="Homepage"><span class="brand-mark">MK</span><span>Marcos Kallis</span></a>
        <nav class="links" aria-label="Main navigation">
          <a href="/blog/">Blog</a>
          <a href="/apps/">Apps</a>
          <a href="/admin/">Admin</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer>
      <div class="container">Built for ideas, experiments and useful little fixes. MK 🟠 2026</div>
    </footer>
  </body>
</html>
