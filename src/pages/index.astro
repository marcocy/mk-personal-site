---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Marcos Kallis | Ideas Lab" description="Personal blog, digital experiments and web app portfolio by Marcos Kallis.">
  <section class="hero">
    <div class="card hero-card">
      <div class="eyebrow">Ideas lab · blog · apps</div>
      <h1>Building useful ideas into visible impact.</h1>
      <p class="lead">A personal space for articles, digital experiments, small web apps, business communication ideas and practical innovation. Corporate enough to wear a tie, experimental enough to occasionally break one.</p>
      <div class="button-row">
        <a class="button primary" href="/blog/">Read the blog</a>
        <a class="button secondary" href="/apps/">Explore apps</a>
      </div>
    </div>
    <aside class="card side-card">
      <div class="stat"><strong>01</strong><span>Blog posts and short articles</span></div>
      <div class="stat"><strong>02</strong><span>HTML/JS apps and prototypes</span></div>
      <div class="stat"><strong>03</strong><span>Experiments in useful automation</span></div>
    </aside>
  </section>

  <section class="section grid">
    <article class="card mini-card">
      <h3>Business communication</h3>
      <p>Thoughts on positioning, public messages, events, and making institutional work more visible.</p>
    </article>
    <article class="card mini-card">
      <h3>Digital tools</h3>
      <p>Small practical apps, prototypes and “vibe-coded” utilities that solve real-life micro-problems.</p>
    </article>
    <article class="card mini-card">
      <h3>Innovation notes</h3>
      <p>Observations on AI, productivity, organisations and the future of work.</p>
    </article>
  </section>
</BaseLayout>
